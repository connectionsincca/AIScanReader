# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys  (must have GPT-4o access)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ─── SMTP / Email ─────────────────────────────────────────────────────────────
# Gmail example — use an App Password (not your main Gmail password)
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_NAME=Tanon Immigration Portal
SMTP_FROM=noreply@yourdomain.com

# ─── Agency inbox ─────────────────────────────────────────────────────────────
# All completed intake packages are emailed here
AGENCY_EMAIL=intake@immigrationagency.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set this to your frontend URL in production (Railway URL or custom domain)
# Leave as default for local development
CLIENT_URL=http://localhost:5173
