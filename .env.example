# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Required: gpt-4o is used for document classification and OCR extraction
OPENAI_API_KEY=sk-...

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Works with Gmail, SendGrid, Mailgun, AWS SES, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465 (SSL), false for 587 (STARTTLS)
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# Sender display name + address
SMTP_FROM_NAME=Immigration Portal
SMTP_FROM=noreply@immigrationportal.com

# ─── Agency ────────────────────────────────────────────────────────────────────
# Destination inbox that receives all intake submissions
AGENCY_EMAIL=intake@immigrationagency.com

# ─── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
